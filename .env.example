# ===================================
# SmartHR Environment Variables
# ===================================
# Copy this file to .env and fill in your values.
# Spring Boot will read these via ${ENV_VAR} placeholders in application.properties.

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5432/smarthr
DB_USERNAME=postgres
DB_PASSWORD=your_db_password

# --- JWT ---
JWT_SECRET=your_base64_encoded_secret_key_here
JWT_EXPIRATION=86400000

# --- AI / LLM ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Document Storage ---
DOCUMENT_STORAGE_PATH=./uploads
